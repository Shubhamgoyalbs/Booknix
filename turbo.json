{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"PORT",
		"REFRESH_TOKEN_SECRET",
		"REFRESH_TOKEN_EXPIRES_IN",
		"ACCESS_TOKEN_SECRET",
		"ACCESS_TOKEN_EXPIRES_IN",
		"RESEND_API_KEY",
		"OTP_SECRET",
		"OTP_TTL_SECONDS"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			],
			"outputs": [
				".next/**",
				"!.next/cache/**"
			]
		},
		"lint": {
			"dependsOn": [
				"^lint"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				".env*"
			]
		},
		"check-types": {
			"dependsOn": [
				"^check-types"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
