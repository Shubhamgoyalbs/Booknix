generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -- ENUMS

enum EventBookingStatus {
  WAITING
  STARTED
  CLOSED
}

enum EventStatus {
  OPEN
  CLOSED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// -- MODELS

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String
  lastName      String
  profilePicUrl String?
  password      String
  verified      Boolean        @default(false)
  isOrganizer   Boolean        @default(false)
  refreshToken  String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  events        Event[]
  bookings      Booking[]
  subscribes    Subscribe[]
  bookmarks     Bookmark[]
  notifications Notification[]
  ticketLocks   TicketLock[]

  @@index([email])
}

model Event {
  id                 String             @id @default(cuid())
  title              String
  description        String
  imageUrl           String
  location           String
  dateTime           DateTime
  duration           Int // duration in minutes
  eventBookingStatus EventBookingStatus
  eventStatus        EventStatus
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  eventTypeId        String
  organizerId        String
  couponId           String?
  eventType          EventType          @relation(fields: [eventTypeId], references: [id])
  organizer          User               @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  coupon             Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  ticketTypes        TicketType[]
  bookings           Booking[]
  subscribes         Subscribe[]
  bookmarks          Bookmark[]

  @@index([eventTypeId])
  @@index([organizerId])
  @@index([dateTime])
  @@index([eventStatus])
}

model TicketType {
  id           String        @id @default(cuid())
  typeName     String
  available    Int
  total        Int
  imageUrl     String
  price        Float
  eventId      String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookingItems BookingItem[]
  ticketLocks  TicketLock[]

  @@unique([eventId, typeName])
  @@index([eventId])
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  seen      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, seen])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String
  minPrice        Float
  maxDiscount     Float
  discountPercent Float
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  events          Event[]
  bookings        Booking[]

  @@index([code])
}

model Booking {
  id              String        @id @default(cuid())
  totalAmount     Float
  discountPercent Float         @default(0)
  finalAmount     Float
  paymentStatus   PaymentStatus @default(PENDING)
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  eventId         String
  couponId        String?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  coupon          Coupon?       @relation(fields: [couponId], references: [id], onDelete: SetNull)
  bookingItems    BookingItem[]

  @@index([userId])
  @@index([eventId])
  @@index([paymentStatus])
  @@index([expiresAt])
}

model BookingItem {
  id           String     @id @default(cuid())
  quantity     Int
  createdAt    DateTime   @default(now())
  bookingId    String
  ticketTypeId String
  booking      Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)

  @@index([bookingId])
  @@index([ticketTypeId])
}

model Bookmark {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  eventId   String
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model Subscribe {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  eventId   String
  userId    String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model TicketLock {
  id           String     @id @default(cuid())
  quantity     Int
  expiresAt    DateTime
  createdAt    DateTime   @default(now())
  userId       String
  ticketTypeId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@index([ticketTypeId])
}

model EventType {
  id        String   @id @default(cuid())
  typeName  String   @unique
  createdAt DateTime @default(now())
  events    Event[]

  @@index([typeName])
}

model PaymentLink {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  // You'll handle this later
}
